# Backend env premenné. Skopíruj do .env (gitignored) a doplň hodnoty.

APP_ENV=local
APP_DEBUG=true

# Lokálny Docker MariaDB (z docker-compose.yml).
DB_HOST=db
DB_PORT=3306
DB_NAME=firol
DB_USER=firol
DB_PASS=firol

# Produkcia (Websupport):
# DB_HOST=l8uz.your-database.de
# DB_PORT=3306
# DB_NAME=<from-websupport>
# DB_USER=<from-websupport>
# DB_PASS=<from-websupport>

# Stripe — všetky 4 hodnoty z dashboard.stripe.com (test mode pre dev, live pre prod).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# iDoklad — z app.idoklad.cz/Account/Authorization (OAuth2 client_credentials).
# Žiadny sandbox neexistuje; nechaj DRAFT_MODE=true v dev/staging aby faktúry
# šli ako Draft (nepošlú sa zákazníkovi, neminú dokumentové číslo).
IDOKLAD_CLIENT_ID=
IDOKLAD_CLIENT_SECRET=
IDOKLAD_DRAFT_MODE=true

# Verejná URL aplikácie — používa Stripe pre návrat z Checkoutu a Customer Portal.
APP_BASE_URL=http://localhost:5173
