# Backend env premenné. Skopíruj do .env (gitignored) a doplň hodnoty.

APP_ENV=local
APP_DEBUG=true

# Lokálny Docker MariaDB (z docker-compose.yml).
DB_HOST=db
DB_PORT=3306
DB_NAME=firol
DB_USER=firol
DB_PASS=firol

# Produkcia: nastav podľa konfigurácie tvojho production servera.
# DB_HOST=<prod-db-host>
# DB_PORT=3306
# DB_NAME=<prod-db-name>
# DB_USER=<prod-db-user>
# DB_PASS=<prod-db-pass>

# Stripe — všetky 4 hodnoty z dashboard.stripe.com (test mode pre dev, live pre prod).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# iDoklad — z app.idoklad.cz/Account/Authorization (OAuth2 client_credentials).
# Žiadny sandbox neexistuje; nechaj DRAFT_MODE=true v dev/staging aby faktúry
# šli ako Draft (nepošlú sa zákazníkovi, neminú dokumentové číslo).
IDOKLAD_CLIENT_ID=
IDOKLAD_CLIENT_SECRET=
IDOKLAD_DRAFT_MODE=true

# Verejná URL aplikácie — používa Stripe pre návrat z Checkoutu a Customer Portal.
APP_BASE_URL=http://localhost:5173

# Email(y) účtov, ktoré majú prístup do Settings → Admin (trial_days, ceny).
# Comma-separated. Bez tohto je admin sekcia nedostupná každému.
ADMIN_EMAIL=

# SMTP transakčné maily — prázdny SMTP_HOST v deve zaloguje obsah do php logov.
# V produkcii doplň hodnoty od tvojho SMTP providera (Mailgun / SendGrid /
# vlastný server). SMTP_ENCRYPTION akceptuje: tls | ssl | none.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
MAIL_FROM=
MAIL_FROM_NAME=Firol

# Dokumentácia PO — generovanie dokumentov.
# Backend naplní Word šablónu (backend/docx/render.mjs, docxtemplater) a
# následne ju skonvertuje na PDF. Node beží ako child proces; konverziu
# zabezpečí Gotenberg (kontajner) alebo LibreOffice (binárka na hostovi).
FIROL_NODE_BIN=node
# gotenberg | libreoffice
FIROL_PDF_CONVERTER=gotenberg
# Pre FIROL_PDF_CONVERTER=gotenberg — URL bežiacej Gotenberg inštancie.
FIROL_GOTENBERG_URL=http://gotenberg:3000
# Pre FIROL_PDF_CONVERTER=libreoffice — cesta k soffice/libreoffice binárke.
# FIROL_LIBREOFFICE_BIN=soffice
