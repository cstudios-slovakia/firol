# Apache rewrite pravidlá — produkcia (Websupport shared hosting).
# Tento súbor sa pri deploye umiestni do root cstudios.ninja/sub/firol/
# spolu s index.html (SPA) a index.php (PHP API).

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Disable MultiViews (môžu kolidovať s rewrite-om)
    Options -MultiViews

    # Všetky /api/* požiadavky idú do PHP front controllera.
    RewriteRule ^api(/.*)?$ index.php [L,QSA]

    # Skutočné súbory a adresáre (assets/, static, atď.) servuje Apache priamo.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Všetko ostatné padá na SPA index.html (React Router client-side).
    RewriteRule ^ index.html [L]
</IfModule>

# Skry citlivé súbory v prípade, že by sa náhodou dostali do webrootu.
<FilesMatch "^\.env|composer\.(json|lock)$">
    Require all denied
</FilesMatch>

# Základné security headers.
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
